{"config":{"lang":["zh"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u9996\u9875","text":""},{"location":"#extrautilities","title":"ExtraUtilities","text":""},{"location":"#mindustry","title":"Mindustry \u6269\u5c55\u6a21\u7ec4 \u00b7 \u5b98\u65b9\u6587\u6863\u5e93","text":"<p> \u65b0\u624b\u8f85\u52a9\uff0c\u9ad8\u9636\u5355\u4f4d\uff0c\u9ad8\u9636\u70ae\u5854\uff0c\u9ad8\u9636\u5de5\u5382\uff0c\u89c6\u89c9\u8c03\u6574 | \u8f7b\u91cf\u5316\u9ad8\u517c\u5bb9\u6a21\u7ec4 </p>  \u66f4\u65b0\u65e5\u5fd7&amp;\u83b7\u53d6\u6a21\u7ec4"},{"location":"#_1","title":"\u6a21\u7ec4\u4ecb\u7ecd","text":"<p>ExtraUtilities \u7ed9\u4e88\u539f\u7248\u6e38\u620f\u4e0a\u7684\u4f53\u9a8c\u6269\u5c55\uff1a</p> <ul> <li>\u9ad8\u7ea7\u5355\u4f4d\u5de5\u5382\u70ae\u5854</li> <li>\u5168\u65b0\u6218\u5f79\u5730\u56fe\u73a9\u6cd5</li> <li>\u8f85\u52a9\u8bbe\u7f6e\u4f18\u5316\u6e38\u620f\u4f53\u9a8c</li> <li>\u795e\u79d8\u673a\u5236\u4ee5\u53ca\u4f5c\u8005\u7684\u5c0f\u5de7\u601d</li> </ul> <p>\u672c\u6587\u6863\u6536\u5f55\u5168\u90e8\u5efa\u7b51\u3001\u7269\u54c1\u3001\u5355\u4f4d\u6570\u503c\u548c\u5177\u4f53\u673a\u5236\u3002</p>"},{"location":"#_2","title":"\u5168\u5206\u7c7b\u5bfc\u822a","text":"\u5efa\u7b51\u56fe\u9274  <p>\u5168\u90e8\u5efa\u7b51\u6570\u503c\u673a\u5236&amp;\u90e8\u5206\u6f14\u793a</p> \u8fdb\u5165\u5efa\u7b51\u5206\u7c7b \u2192 \u8d44\u6e90\u7269\u54c1  <p>EU\u5168\u90e8\u7269\u54c1\u5c55\u793a\uff08WTMF\uff09</p> \u67e5\u770b\u5168\u90e8\u7269\u54c1 \u2192 \u4f5c\u6218\u5355\u4f4d  <p>\u5168\u90e8\u5355\u4f4d\u5c5e\u6027\u4ee5\u53ca\u90e8\u5206\u653b\u51fb\u6548\u679c\u52a8\u56fe\u6f14\u793a</p> \u5355\u4f4d\u8be6\u60c5\u9875 \u2192 \u72b6\u6001\u6548\u679c  <p>EU\u90e8\u5206\u7279\u6b8a\u6548\u679c\u4e00\u89c8</p> \u6548\u679c\u8be6\u89e3 \u2192 \u6218\u5f79\u5730\u56fe  <p>EU\u65b0\u589e\u5730\u56fe\u6218\u5f79\uff08\u53ef\u80fd\u5267\u900f\uff09</p> \u5730\u56fe\u4e00\u89c8 \u2192 \u8bbe\u7f6e\u8bb2\u89e3  <p>EU\u5168\u90e8\u8bbe\u7f6e\u548c\u529f\u80fd\u4ecb\u7ecd</p> \u8bbe\u7f6e\u529f\u80fd \u2192 \u72ec\u7acb\u6a21\u5f0f  <p>EU\u8089\u9e3d\u6a21\u5f0f\u4ecb\u7ecd</p> \u8089\u9e3d\u6a21\u5f0f \u2192 \u66f4\u65b0\u65e5\u5fd7  <p>\u7248\u672c\u65b0\u589e\u5185\u5bb9\u3001\u5e73\u8861\u8c03\u6574\u3001BUG\u4fee\u590d\u8bb0\u5f55</p> \u67e5\u770b\u66f4\u65b0 \u2192 \u5e38\u89c1\u95ee\u9898  <p>\u5b89\u88c5\u51b2\u7a81\u3001\u5d29\u6e83\u62a5\u9519\u3001\u73a9\u6cd5\u7591\u95ee\u89e3\u7b54</p> \u95ee\u9898\u6c47\u603b \u2192 <p> </p>"},{"location":"#_3","title":"\u6587\u6863\u7ef4\u62a4","text":"<ul> <li>\u5f00\u6e90\u4ed3\u5e93\uff1a\u2192 \u524d\u5f80\u4ed3\u5e93 \u2190</li> <li>\u6570\u503c\u9519\u8bef\u3001\u7f3a\u5931\u5185\u5bb9\u6b22\u8fce\u63d0\u4ea4 Issues \u8865\u5145\u4fee\u6b63</li> </ul>"},{"location":"building/main/","title":"\u5168\u90e8\u5efa\u7b51\u4e00\u89c8","text":"\u8fd0\u8f93 \u5236\u9020 \u9632\u5fa1 \u6d41\u4f53 \u7535\u529b \u751f\u4ea7 \u70ae\u5854 \u5355\u4f4d \u903b\u8f91"},{"location":"building/turret/T2duo/","title":"T2\u53cc\u7ba1","text":"<p> \u2190 \u8fd4\u56de\u5efa\u7b51\u603b\u89c8 </p> T2-\u53cc\u7ba1 <p>\u5185\u90e8ID\uff1a<code>extra-utilities-T2-duo</code></p> <p>biu-biu-</p>"},{"location":"building/turret/T2duo/#_1","title":"\u7528\u9014","text":"<p>\u5411\u654c\u4eba\u5feb\u901f\u4ea4\u66ff\u53d1\u5c04\u5b50\u5f39\uff0c\u76f8\u6bd4\u4e8e\u539f\u7248\u53cc\u7ba1\u70ae\u5854\u62e5\u6709\u5168\u65b9\u4f4d\u66f4\u4f18\u79c0\u7684\u5c5e\u6027\u3002</p>"},{"location":"building/turret/T2duo/#_2","title":"\u57fa\u7840\u5c5e\u6027","text":"\u53c2\u6570 \u6570\u503c \u751f\u547d\u503c 320 \u5360\u5730\u9762\u79ef 1\u00d71 \u5efa\u9020\u8017\u65f6 0.583 \u79d2 \u5efa\u9020\u6d88\u8017 \u94dc \u00d770"},{"location":"building/turret/T2duo/#_3","title":"\u6d41\u4f53\u50a8\u5b58","text":"\u9879\u76ee \u6570\u503c \u6d41\u4f53\u603b\u5bb9\u91cf 20 \u5355\u4f4d"},{"location":"building/turret/T2duo/#_4","title":"\u4f5c\u6218\u5c5e\u6027","text":"\u5c5e\u6027 \u8be6\u60c5 \u653b\u51fb\u5c04\u7a0b 19 \u683c \u5c04\u51fb\u8bef\u5dee 2\u00b0 \u57fa\u7840\u5f00\u706b\u901f\u7387 4\u6b21/\u79d2 \u53ef\u653b\u51fb\u7a7a\u4e2d\u5355\u4f4d \u662f \u53ef\u653b\u51fb\u5730\u9762\u5355\u4f4d \u662f \u5f39\u836f\u6700\u5927\u5bb9\u91cf 30 \u53d1"},{"location":"building/turret/T2duo/#_5","title":"\u5f39\u836f","text":""},{"location":"building/turret/T2duo/#_6","title":"<p>\u94dc\u5b50\u5f39 </p> <ul> <li>\u5355\u53d1\u4f24\u5bb3\uff1a9</li> <li>\u88c5\u586b\u500d\u7387\uff1a2\u00d7</li> </ul>","text":""},{"location":"building/turret/T2duo/#_7","title":"<p>\u77f3\u58a8\u5b50\u5f39 </p> <ul> <li>\u5355\u53d1\u4f24\u5bb3\uff1a18</li> <li>\u5c04\u7a0b\u63d0\u5347\uff1a+2 \u683c</li> <li>\u88c5\u586b\u500d\u7387\uff1a4\u00d7</li> <li>\u5f00\u706b\u901f\u7387\uff1a-20%</li> </ul>","text":""},{"location":"building/turret/T2duo/#_8","title":"<p>\u7845\u5b50\u5f39 </p> <ul> <li>\u5355\u53d1\u4f24\u5bb3\uff1a12</li> <li>\u88c5\u586b\u500d\u7387\uff1a5\u00d7</li> <li>\u5f00\u706b\u901f\u7387\uff1a+50%</li> <li>\u5f39\u9053\u5177\u5907\u8ffd\u8e2a\u6548\u679c</li> </ul>","text":""},{"location":"building/turret/T2duo/#_9","title":"\u53ef\u9009\u5f3a\u5316","text":"<p> \u6c34 \uff08\u6d88\u8017\uff1a6/\u79d2\uff09\u5f00\u706b\u901f\u7387\u63d0\u5347\u81f3 120%  \u51b7\u51bb\u6db2 \uff08\u6d88\u8017\uff1a6/\u79d2\uff09\u5f00\u706b\u901f\u7387\u63d0\u5347\u81f3 145%</p>"},{"location":"building/turret/T2duo/#_10","title":"\u56f0\u96be\u6a21\u5f0f\u7279\u6b8a\u6539\u52a8","text":"<p>\"\u6307\u671b\u5b83\u8f93\u51fa\u4e0d\u5982\u6307\u671b\u5b83\u5f53\u5899\"</p> <ul> <li>\u70ae\u5854\u63cf\u8ff0\u53d8\u4e3a\uff1a\u201c\u5411\u654c\u4eba\u4ea4\u66ff\u53d1\u5c04\u5b50\u5f39\u3002\u653b\u901f\u6bd4\u53cc\u7ba1\u4f4e\uff0c\u4f46\u662f\u751f\u547d\u503c\u5f88\u9ad8\u3002\u201d</li> <li>\u5f00\u706b\u901f\u7387\u7531\u539f\u6709\u76844/s\u53d8\u4e3a1.67/s\uff0c\u8fd9\u610f\u5